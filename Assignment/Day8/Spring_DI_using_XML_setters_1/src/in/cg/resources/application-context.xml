<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

	<!-- bean definitions here -->
	<bean id="add1" class="in.cg.beans.Address">
		<property name="hNo" value="1991" />
		<property name="city" value="Bapatla" />
		<property name="pincode" value="522101" />
	</bean>

	<!-- bean definitions here -->
	<bean id="stu1" class="in.cg.beans.Student">
		<property name="id" value="1002" />
		<property name="name" value="Madhav" />
		<property name="email" value="madhav@gmail.com" />
		<property name="address" ref="add1" />
	</bean>
	
</beans>